{
    "title": "Service Health",
    "uid": "service-health",
    "panels": [
        {
            "title": "Postgres",
            "type": "stat",
            "id": 1,
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "max(up{job=\"integrations/postgres\"})",
                    "refId": "A"
                }
            ],
            "datasource": "Prometheus",
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN"
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "UP"
                                }
                            }
                        }
                    ]
                }
            },
            "options": {
                "colorMode": "background",
                "graphMode": "none",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            }
        },
